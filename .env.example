# 実データ投入と Grafana views 用の PostgreSQL。
# 実資産データには TEST_DATABASE_URL を使わないでください。
DATABASE_URL=postgres://equinaut:equinaut@localhost:5432/equinaut

# Docker Compose の PostgreSQL 初期値。
# app service からは service name の postgres:5432 で接続します。
POSTGRES_USER=equinaut
POSTGRES_PASSWORD=equinaut
POSTGRES_DB=equinaut
POSTGRES_PORT=5432

# bitbank local development credentials。
# bitbank account settings で許可される場合は read-only API key を推奨します。
BITBANK_API_KEY=
BITBANK_API_SECRET=
BITBANK_ACCESS_TIME_WINDOW_MS=1000

# 各 ingestion HTTP request の application-level timeout（ms、1000-120000、default: 30000）。
INGESTION_HTTP_REQUEST_TIMEOUT_MS=30000

# Docker / file-mounted secret を使う場合の設定。
# これらを設定した場合、application はまず file contents を読み、上の env values に fallback します。
# BITBANK_API_KEY_FILE=/run/secrets/bitbank_api_key
# BITBANK_API_SECRET_FILE=/run/secrets/bitbank_api_secret

# bitFlyer local development credentials。
# bitFlyer account settings では read-only API key を使用してください。
BITFLYER_API_KEY=
BITFLYER_API_SECRET=

# Docker / file-mounted secret を使う場合の設定。
# BITFLYER_API_KEY_FILE=/run/secrets/bitflyer_api_key
# BITFLYER_API_SECRET_FILE=/run/secrets/bitflyer_api_secret

# Saxo portfolio snapshot API。
# portfolio-snapshot.v1 JSON を返す read-only endpoint を Bearer token で呼び出します。
SAXO_PORTFOLIO_API_URL=
SAXO_PORTFOLIO_API_SECRET=

# Docker / file-mounted secret を使う場合の設定。
# SAXO_PORTFOLIO_API_SECRET_FILE=/run/secrets/saxo_portfolio_api_secret

# Docker Compose worker が read-only mount する local secret files の配置先。
# この directory は Git tracking と Docker build context から除外されます。
EQUINAUT_SECRETS_DIR=./secrets
# - bitbank_api_key
# - bitbank_api_secret
# - bitflyer_api_key
# - bitflyer_api_secret
# - saxo_portfolio_api_secret
