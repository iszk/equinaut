# PostgreSQL for real ingestion and Grafana views.
# Do not use TEST_DATABASE_URL for real asset data.
DATABASE_URL=postgres://equinaut:change-me@localhost:5432/equinaut

# bitbank local development credentials.
# Prefer read-only API keys if bitbank account settings allow it.
BITBANK_API_KEY=
BITBANK_API_SECRET=
BITBANK_ACCESS_TIME_WINDOW_MS=1000

# Docker / file-mounted secret preference.
# If these are set, the application reads the file contents first and falls back to the env values above.
# BITBANK_API_KEY_FILE=/run/secrets/bitbank_api_key
# BITBANK_API_SECRET_FILE=/run/secrets/bitbank_api_secret
