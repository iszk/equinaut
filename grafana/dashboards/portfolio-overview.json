          "rawSql": "select\n  coalesce(sum(value_jpy), 0)::numeric(38, 18) as total_value_jpy\nfrom portfolio_latest_assets\nwhere source_id in (${source_id:sqlstring})\n  and scope_id in (${scope_id:sqlstring});",
