services:

  ingestion-worker:
    restart: unless-stopped
    image: equinaut-ingestion:local
    build:
      context: .
    command:
      - sleep
      - infinity
    environment:
      - TZ=Asia/Tokyo
      - LANG=C.UTF-8
      - DATABASE_URL=postgres://${POSTGRES_USER:-equinaut}:${POSTGRES_PASSWORD:-equinaut}@postgres:5432/${POSTGRES_DB:-equinaut}
      - BITBANK_API_KEY_FILE=/run/secrets/bitbank_api_key
      - BITBANK_API_SECRET_FILE=/run/secrets/bitbank_api_secret
      - BITBANK_ACCESS_TIME_WINDOW_MS=${BITBANK_ACCESS_TIME_WINDOW_MS:-5000}
      - BITFLYER_API_KEY_FILE=/run/secrets/bitflyer_api_key
      - BITFLYER_API_SECRET_FILE=/run/secrets/bitflyer_api_secret
      - SAXO_PORTFOLIO_API_URL=${SAXO_PORTFOLIO_API_URL:-}
      - SAXO_PORTFOLIO_API_SECRET_FILE=/run/secrets/saxo_portfolio_api_secret
    init: true
    depends_on:
      postgres:
        condition: service_healthy
    secrets:
      - bitbank_api_key
      - bitbank_api_secret
      - bitflyer_api_key
      - bitflyer_api_secret
      - saxo_portfolio_api_secret
    labels:
      ofelia.enabled: "true"
      ofelia.job-exec.equinaut-bitbank-ingestion.schedule: "0 0,15,30,45 * * * *"
      ofelia.job-exec.equinaut-bitbank-ingestion.command: "/usr/bin/timeout --signal=TERM --kill-after=30s 10m npm run ingest -- bitbank"
      ofelia.job-exec.equinaut-bitbank-ingestion.no-overlap: "true"
      ofelia.job-exec.equinaut-bitbank-ingestion.user: "node"
      ofelia.job-exec.equinaut-bitflyer-ingestion.schedule: "0 5,20,35,50 * * * *"
      ofelia.job-exec.equinaut-bitflyer-ingestion.command: "/usr/bin/timeout --signal=TERM --kill-after=30s 10m npm run ingest -- bitflyer"
      ofelia.job-exec.equinaut-bitflyer-ingestion.no-overlap: "true"
      ofelia.job-exec.equinaut-bitflyer-ingestion.user: "node"
      ofelia.job-exec.equinaut-saxo-ingestion.schedule: "0 10,25,40,55 * * * *"
      ofelia.job-exec.equinaut-saxo-ingestion.command: "/usr/bin/timeout --signal=TERM --kill-after=30s 10m npm run ingest -- saxo"
      ofelia.job-exec.equinaut-saxo-ingestion.no-overlap: "true"
      ofelia.job-exec.equinaut-saxo-ingestion.user: "node"

  postgres:
    restart: unless-stopped
    container_name: equinaut-pg
    image: postgres:18
    volumes:
      - pg-data:/var/lib/postgresql
    environment:
      - TZ=Asia/Tokyo
      - LANG=C.UTF-8
      - POSTGRES_USER=${POSTGRES_USER:-equinaut}
      - POSTGRES_DB=${POSTGRES_DB:-equinaut}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-equinaut}
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U "$${POSTGRES_USER:-equinaut}" -d "$${POSTGRES_DB:-equinaut}"
      interval: 5s
      timeout: 5s
      retries: 12

volumes:
  pg-data:

secrets:
  bitbank_api_key:
    file: ${EQUINAUT_SECRETS_DIR:-./secrets}/bitbank_api_key
  bitbank_api_secret:
    file: ${EQUINAUT_SECRETS_DIR:-./secrets}/bitbank_api_secret
  bitflyer_api_key:
    file: ${EQUINAUT_SECRETS_DIR:-./secrets}/bitflyer_api_key
  bitflyer_api_secret:
    file: ${EQUINAUT_SECRETS_DIR:-./secrets}/bitflyer_api_secret
  saxo_portfolio_api_secret:
    file: ${EQUINAUT_SECRETS_DIR:-./secrets}/saxo_portfolio_api_secret
